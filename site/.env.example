# Base URL of the backend API.
#
# Leave UNSET in development — Vite proxies /api/* to the local backend
# (see vite.config.ts).
#
# Set in production (Cloudflare Pages → Settings → Environment variables)
# to your API origin, with no trailing slash. Example:
#
#   VITE_API_URL=https://api.tripwe.example
VITE_API_URL=
